# MuleRouter Skill — Required Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Get your API key at: https://www.mulerouter.ai/app/api-keys

# Required: API key (sent as Bearer token in Authorization header)
MULEROUTER_API_KEY=your-api-key-here

# Required — pick ONE of the two below:

# Option 1: Custom base URL (takes priority over MULEROUTER_SITE)
MULEROUTER_BASE_URL=https://api.mulerouter.ai

# Option 2: Site name (used if MULEROUTER_BASE_URL is not set)
# MULEROUTER_SITE=mulerouter   # or: mulerun
